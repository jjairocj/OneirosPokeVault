# ============================================================
# Variables para el proyecto SERVER en Vercel
# (Settings → Environment Variables del proyecto de la API)
# ============================================================

# Base de datos - Neon
DATABASE_URL=postgresql://neondb_owner:<password>@<host>.neon.tech/neondb?sslmode=require&channel_binding=require

# JWT - Generá strings aleatorios fuertes:
#   openssl rand -hex 32
JWT_ACCESS_SECRET=<genera-con-openssl-rand-hex-32>
JWT_REFRESH_SECRET=<genera-con-openssl-rand-hex-32>
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Cookie - Generá un string aleatorio fuerte:
#   openssl rand -hex 32
COOKIE_SECRET=<genera-con-openssl-rand-hex-32>

# Nodo
NODE_ENV=production

# CORS - URL del frontend (proyecto cliente en Vercel)
# Ej: https://oneiros-poke-vault.vercel.app
CORS_ORIGIN=https://<tu-proyecto-cliente>.vercel.app


# ============================================================
# Variables para el proyecto CLIENT en Vercel
# (Settings → Environment Variables del proyecto del cliente)
# ============================================================

# URL del servidor (proyecto server en Vercel)
# Ej: https://oneiros-poke-vault-api.vercel.app
VITE_API_URL=https://<tu-proyecto-servidor>.vercel.app
