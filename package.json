{
  "name": "oneiros-pokevault",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"npm run dev -w client\" \"npm run dev -w server\"",
    "db:push": "drizzle-kit push --config=server/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=server/drizzle.config.ts",
    "db:migrate": "drizzle-kit generate --config=server/drizzle.config.ts && drizzle-kit migrate --config=server/drizzle.config.ts",
    "build": "npm run build -w client && npm run build -w server",
    "start": "node server/dist/index.js",
    "test": "npm run test -w server && npm run test -w client"
  },
  "dependencies": {
    "typescript": "^5.7.3",
    "@types/node": "^22.12.0",
    "@types/express": "^5.0.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.7"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.8",
    "tsx": "^4.19.2",
    "@types/bcrypt": "^5.0.2",
    "@types/supertest": "^7.2.0"
  }
}